    <div id="zoe-fab" onclick="toggleZoe()" class="fixed bottom-10 right-10 z-[1000] w-20 h-20 bg-green-600 rounded-[30px] flex items-center justify-center text-white text-4xl shadow-2xl ring-8 ring-white dark:ring-slate-900 active:scale-90 transition-all">
        <i class="fas fa-leaf"></i>
    </div>

    <div id="zoe-window" class="fixed bottom-32 right-10 left-10 md:left-auto md:w-[450px] h-[600px] bg-white dark:bg-slate-900 rounded-[55px] shadow-2xl z-[1001] border border-green-50 dark:border-slate-800 hidden flex-col animate-slide-up overflow-hidden">
        <div class="bg-green-600 p-8 text-white flex justify-between items-center font-black">
            <span class="tracking-widest text-xs"><i class="fas fa-robot text-lg mr-2"></i> ZOE AI</span>
            <button onclick="toggleZoe()"><i class="fas fa-times text-xl"></i></button>
        </div>
        <div id="chat-content" class="flex-1 p-8 overflow-y-auto bg-slate-50 dark:bg-slate-950 flex flex-col space-y-6">
            <div class="bg-white dark:bg-slate-800 p-6 rounded-[30px] rounded-tl-none shadow-sm text-sm leading-relaxed border border-slate-100 dark:border-slate-700">
                ¡Paz y Bien, Michael! Tu servidor local en Tarija está listo. ¿Qué quieres subir hoy? 🌱
            </div>
        </div>
        <div class="p-6 bg-white dark:bg-slate-900 border-t flex gap-4">
            <input type="text" id="chat-in" placeholder="Comando..." class="flex-1 bg-slate-100 dark:bg-slate-800 rounded-[25px] px-8 py-5 outline-none text-sm font-bold">
            <button onclick="sendZoe()" class="bg-green-600 text-white w-16 h-16 rounded-[25px] flex items-center justify-center shadow-xl"><i class="fas fa-paper-plane text-sm"></i></button>
        </div>
    </div>

    <script>
        let isAuth = false;
        let isEdit = false;

        function openAuth() { document.getElementById('auth-screen').classList.remove('hidden'); }
        function closeAuth() { document.getElementById('auth-screen').classList.add('hidden'); }
        
        function login() {
            const u = document.getElementById('user-in').value;
            const p = document.getElementById('pass-in').value;
            if(u === 'avila.admin' && p === 'admin') {
                isAuth = true;
                closeAuth();
                navigateTo('dashboard');
                document.getElementById('auth-btn').innerText = "Panel";
            } else { alert("Acceso denegado."); }
        }

        function logout() { location.reload(); }

        function navigateTo(id) {
            document.getElementById('page-landing').classList.toggle('hidden', id !== 'landing');
            document.getElementById('page-dashboard').classList.toggle('hidden', id !== 'dashboard');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function toggleDarkMode() { document.body.classList.toggle('dark-mode'); }

        function toggleZoe() {
            const win = document.getElementById('zoe-window');
            win.classList.toggle('hidden');
            if(!win.classList.contains('hidden')) win.style.display = 'flex';
        }

        function sendZoe() {
            const input = document.getElementById('chat-in');
            const box = document.getElementById('chat-content');
            if(!input.value.trim()) return;
            const uDiv = document.createElement('div');
            uDiv.className = 'bg-green-600 text-white p-6 rounded-[30px] rounded-tr-none self-end text-sm max-w-[85%] shadow-lg message-animate font-bold';
            uDiv.innerText = input.value;
            box.appendChild(uDiv);
            input.value = '';
            box.scrollTop = box.scrollHeight;
        }

        function toggleEditor() {
            isEdit = !isEdit;
            const btn = document.getElementById('master-btn');
            const items = document.querySelectorAll('h1, h2, h3, p, span');
            btn.innerText = isEdit ? "GUARDAR" : "EDITOR MAESTRO";
            btn.style.background = isEdit ? "#ef4444" : "#2563eb";
            items.forEach(el => {
                el.contentEditable = isEdit;
                el.classList.toggle('edit-mode-active', isEdit);
            });
        }

        function handleImage(e) {
            const file = e.target.files[0];
            const reader = new FileReader();
            reader.onload = (ev) => {
                const grid = document.getElementById('mural-grid');
                const div = document.createElement('div');
                div.className = 'rounded-[35px] overflow-hidden aspect-square shadow-xl border-4 border-white dark:border-slate-700 bg-white relative group message-animate';
                div.innerHTML = `
                    <img src="${ev.target.result}" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition flex items-center justify-center">
                        <i class="fas fa-trash text-white cursor-pointer p-4 bg-red-600 rounded-full" onclick="this.parentElement.parentElement.remove(); saveMural();"></i>
                    </div>
                `;
                grid.prepend(div);
                saveMural();
            };
            reader.readAsDataURL(file);
        }

        function saveMural() {
            localStorage.setItem('zoe_mural_final', document.getElementById('mural-grid').innerHTML);
        }

        window.onload = () => {
            const saved = localStorage.getItem('zoe_mural_final');
            if(saved) document.getElementById('mural-grid').innerHTML = saved;
        };
    </script>
</body>
</html>

